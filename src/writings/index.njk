---
layout: layouts/base.njk
title: Writings
description: Essays and writing.
---

<h1>Writings</h1>

<ul class="post-list">
	{%- for post in collections.writings %}
	<li>
		<a href="{{ post.url }}">{{ post.data.title }}</a>
		<time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
		{%- if post.data.description %}
		<p>{{ post.data.description }}</p>
		{%- endif %}
	</li>
	{%- endfor %}
</ul>

<p class="post-meta">
	Follow along without a platform: <a href="/feed.xml">Atom feed</a>.
</p>
